## 9. TRIGGER: MATCHING CENTRAL (ad_id → hierarquia completa)

Executa BEFORE INSERT em cada venda.
Lê `ad_id` (ou `utm_content` como fallback), busca na tabela `ads`
pelo `facebook_ad_id` e sobe a hierarquia para preencher os três
campos `matched_*` automaticamente.

```sql
CREATE OR REPLACE FUNCTION public.match_sale_to_ad()
RETURNS TRIGGER AS $$
DECLARE
  v_ad       RECORD;
  v_adset    RECORD;
  v_campaign RECORD;
BEGIN
  -- Fallback: usa utm_content se ad_id não veio preenchido
  IF NEW.ad_id IS NULL AND NEW.utm_content IS NOT NULL THEN
    NEW.ad_id := NEW.utm_content;
  END IF;

  -- Sem ad_id: venda orgânica
  IF NEW.ad_id IS NULL OR NEW.ad_id = '' THEN
    NEW.is_organic := true;
    RETURN NEW;
  END IF;

  -- Busca o anúncio pelo facebook_ad_id
  SELECT id, ad_set_id
  INTO v_ad
  FROM public.ads
  WHERE facebook_ad_id = NEW.ad_id
  LIMIT 1;

  -- Anúncio não encontrado (sync pendente): salva bruto, marca orgânico
  IF NOT FOUND THEN
    NEW.is_organic := true;
    RETURN NEW;
  END IF;

  -- Sobe para conjunto
  SELECT id, campaign_id
  INTO v_adset
  FROM public.ad_sets
  WHERE id = v_ad.ad_set_id
  LIMIT 1;

  -- Sobe para campanha
  IF v_adset IS NOT NULL THEN
    SELECT id
    INTO v_campaign
    FROM public.campaigns
    WHERE id = v_adset.campaign_id
    LIMIT 1;
  END IF;

  -- Preenche referências
  NEW.matched_ad_id       := v_ad.id;
  NEW.matched_ad_set_id   := v_adset.id;
  NEW.matched_campaign_id := v_campaign.id;
  NEW.is_organic          := false;

  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER on_sale_insert_match_ad
  BEFORE INSERT ON public.sales
  FOR EACH ROW EXECUTE FUNCTION public.match_sale_to_ad();
```

