## 11. VIEWS PARA O DASHBOARD

### Performance por anúncio

```sql
CREATE OR REPLACE VIEW public.v_ad_performance AS
SELECT
  a.id                          AS ad_id,
  a.facebook_ad_id,
  a.ad_name,
  a.status,
  a.spend,
  a.impressions,
  a.clicks,
  a.cpm,
  a.cpc,
  COALESCE(s.total_revenue, 0)  AS revenue,
  COALESCE(s.sale_count, 0)     AS sales,
  CASE WHEN a.spend > 0
    THEN ROUND((COALESCE(s.total_revenue, 0) / a.spend)::NUMERIC, 4)
    ELSE 0 END                  AS roas,
  CASE WHEN a.spend > 0
    THEN ROUND(((COALESCE(s.total_revenue, 0) - a.spend) / a.spend * 100)::NUMERIC, 2)
    ELSE 0 END                  AS roi_pct,
  CASE WHEN COALESCE(s.sale_count, 0) > 0
    THEN ROUND((a.spend / s.sale_count)::NUMERIC, 4)
    ELSE 0 END                  AS cpa,
  ads_et.id                     AS ad_set_id,
  ads_et.adset_name,
  c.id                          AS campaign_id,
  c.campaign_name
FROM public.ads a
LEFT JOIN public.ad_sets  ads_et ON ads_et.id = a.ad_set_id
LEFT JOIN public.campaigns c     ON c.id = ads_et.campaign_id
LEFT JOIN (
  SELECT matched_ad_id,
         SUM(amount) AS total_revenue,
         COUNT(*)    AS sale_count
  FROM public.sales
  WHERE status = 'approved'
  GROUP BY matched_ad_id
) s ON s.matched_ad_id = a.id;
```

### Performance por campanha

```sql
CREATE OR REPLACE VIEW public.v_campaign_performance AS
SELECT
  c.id                          AS campaign_id,
  c.facebook_campaign_id,
  c.campaign_name,
  c.status,
  c.spend,
  c.impressions,
  c.clicks,
  c.cpm,
  c.cpc,
  COALESCE(s.total_revenue, 0)  AS revenue,
  COALESCE(s.sale_count, 0)     AS sales,
  CASE WHEN c.spend > 0
    THEN ROUND((COALESCE(s.total_revenue, 0) / c.spend)::NUMERIC, 4)
    ELSE 0 END                  AS roas,
  CASE WHEN c.spend > 0
    THEN ROUND(((COALESCE(s.total_revenue, 0) - c.spend) / c.spend * 100)::NUMERIC, 2)
    ELSE 0 END                  AS roi_pct,
  CASE WHEN COALESCE(s.sale_count, 0) > 0
    THEN ROUND((c.spend / s.sale_count)::NUMERIC, 4)
    ELSE 0 END                  AS cpa
FROM public.campaigns c
LEFT JOIN (
  SELECT matched_campaign_id,
         SUM(amount) AS total_revenue,
         COUNT(*)    AS sale_count
  FROM public.sales
  WHERE status = 'approved'
  GROUP BY matched_campaign_id
) s ON s.matched_campaign_id = c.id;
```

