## 10. FUNÇÃO: REMATCH DE VENDAS ANTERIORES

Roda uma única vez após a primeira sincronização com o Facebook,
para retroagir o matching em vendas que chegaram antes dos anúncios
estarem cadastrados no banco.

```sql
CREATE OR REPLACE FUNCTION public.rematch_unmatched_sales()
RETURNS INTEGER AS $$
DECLARE
  v_sale     RECORD;
  v_ad       RECORD;
  v_adset    RECORD;
  v_campaign RECORD;
  v_count    INTEGER := 0;
BEGIN
  FOR v_sale IN
    SELECT id, ad_id, utm_content
    FROM public.sales
    WHERE matched_ad_id IS NULL
      AND (ad_id IS NOT NULL OR utm_content IS NOT NULL)
  LOOP
    SELECT id, ad_set_id INTO v_ad
    FROM public.ads
    WHERE facebook_ad_id = COALESCE(v_sale.ad_id, v_sale.utm_content)
    LIMIT 1;

    IF FOUND THEN
      SELECT id, campaign_id INTO v_adset
      FROM public.ad_sets WHERE id = v_ad.ad_set_id LIMIT 1;

      SELECT id INTO v_campaign
      FROM public.campaigns WHERE id = v_adset.campaign_id LIMIT 1;

      UPDATE public.sales SET
        matched_ad_id       = v_ad.id,
        matched_ad_set_id   = v_adset.id,
        matched_campaign_id = v_campaign.id,
        is_organic          = false
      WHERE id = v_sale.id;

      v_count := v_count + 1;
    END IF;
  END LOOP;

  RETURN v_count;  -- retorna quantas vendas foram retroativamente vinculadas
END;
$$ LANGUAGE plpgsql;

-- Uso: SELECT public.rematch_unmatched_sales();
```

